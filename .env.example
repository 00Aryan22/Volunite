# Volunite — Environment Variables
# Copy to `.env` at the repository root and fill in your keys.
# All keys are OPTIONAL — the app runs in demo mode without any keys.

# ─── Core URLs ───────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000

# Comma-separated browser origins allowed to call the API (CORS).
# Leave unset for sensible localhost defaults (Streamlit + API).
# Use * only with credentials disabled (not recommended for authenticated apps).
# CORS_ORIGINS=http://localhost:8501,https://your-app.streamlit.app

# Max upload size for CSV + OCR endpoints (megabytes)
# MAX_UPLOAD_MB=10

# ─── Google AI & Cloud ───────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyD9gZYt9IxMhBJoV4NnNmBnAa-YNc4q-xE
GOOGLE_CLOUD_PROJECT=volunite-496316
CLOUD_VISION_API_KEY=AIzaSyCRinXT0S-X8m9-u-CXCYfCQdnVl7b9Rts
GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# ─── Firebase (pick ONE credential style) ────────────────────────────────────
# Option A — path to service account JSON file (preferred for production)
# FIREBASE_SERVICE_ACCOUNT_PATH=/secure/path/to/service-account.json

# Option B — inline JSON (convenient for local dev; avoid in production logs)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Demo HTML dashboard + /auth/login accounts. Set false on Cloud Run / prod.
ENABLE_DEMO_AUTH=true
